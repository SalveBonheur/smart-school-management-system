# Environment Variables for Smart School Transport System

# Server Configuration
NODE_ENV=production
PORT=3006

# Database Configuration (Railway MySQL)
DB_TYPE=mysql
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=smart_school_transport
DB_PORT=3306

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# Development (Optional - for local development)
# NODE_ENV=development
# DB_TYPE=sqlite
# VITE_API_URL=http://localhost:3006/api
