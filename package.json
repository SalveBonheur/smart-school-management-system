{
  "name": "smart-school-transport-system",
  "version": "2.0.0",
  "description": "A comprehensive school transportation management system with modern UI and advanced features",
  "scripts": {
    "start": "cd server && node server.js",
    "dev": "cd server && node server.js",
    "install:all": "npm install && cd client && npm install && cd ../server && npm install",
    "build": "cd client && npm run build",
    "build:prod": "cd client && npm run build && cd .. && npm run copy-build",
    "copy-build": "xcopy client\\dist server\\public /E /I /Y",
    "heroku-postbuild": "npm run build:prod",
    "render-build": "npm run build:prod",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint server/**/*.js",
    "lint:fix": "eslint server/**/*.js --fix",
    "format": "prettier --write server/**/*.js",
    "db:setup": "cd server && node database/setup.js",
    "db:seed": "cd server && node database/seed.js",
    "db:migrate": "cd server && node database/migrate.js",
    "security:audit": "npm audit",
    "security:fix": "npm audit fix",
    "clean": "rm -rf server/logs/*.log"
  },
  "keywords": [
    "school",
    "transport",
    "management",
    "system",
    "nodejs",
    "express",
    "mysql",
    "transportation"
  ],
  "author": "Smart School Transport Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-fileupload": "^1.4.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^6.10.0",
    "express-slow-down": "^1.6.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.3.2",
    "uuid": "^9.0.0",
    "validator": "^13.11.0",
    "winston": "^3.9.0",
    "winston-daily-rotate-file": "^4.7.1",
    "xss": "^1.0.14"
  },
  "devDependencies": {
    "chromedriver": "^148.0.3",
    "eslint": "^8.44.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.27.5",
    "husky": "^8.0.3",
    "jest": "^29.6.1",
    "lint-staged": "^13.2.3",
    "nightwatch": "^3.15.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.0",
    "supertest": "^6.3.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/smart-school-transport-system.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/smart-school-transport-system/issues"
  },
  "homepage": "https://github.com/yourusername/smart-school-transport-system#readme",
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,css,html}": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
